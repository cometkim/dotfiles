{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "tools": {
    "lsp": true
  },
  "plugin": [
    "opencode-claude-auth@1.5.0"
  ],
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["chrome-devtools-mcp", "--no-usage-statistics"]
    },
    "zai-mcp-server": {
      "type": "local",
      "command": ["zai-mcp-server"],
      "environment": {
        "Z_AI_API_KEY": "{env:ZAI_API_KEY}",
        "Z_AI_MODE": "ZAI"
      }
    },
    "web-search-prime": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "Bearer {env:ZAI_API_KEY}"
      }
    },
    "web-reader": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_reader/mcp",
      "headers": {
        "Authorization": "Bearer {env:ZAI_API_KEY}"
      }
    },
    "zread": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/zread/mcp",
      "headers": {
        "Authorization": "Bearer {env:ZAI_API_KEY}"
      }
    },
    "cloudflare-docs": {
      "type": "remote",
      "url": "https://docs.mcp.cloudflare.com/mcp"
    }
  },
  "provider": {
    "backend.ai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Backend.AI GO",
      "options": {
        "baseURL": "http://localhost:39080/v1"
      },
      "models": {
        "unsloth/Qwen3.5-9B": {}
      }
    }
  }
}
